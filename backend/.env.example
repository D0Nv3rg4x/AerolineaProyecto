# ══════════════════════════════════════════════
# CONFIGURACIÓN DEL BACKEND — SkyNova Airlines
# ══════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Completa los valores con tus propios datos
# 3. NUNCA subas el archivo .env a GitHub
#
# ══════════════════════════════════════════════

# Puerto del servidor (puedes dejarlo en 3001)
PORT=3001

# Tu correo Gmail
EMAIL_USER=

# Contraseña de Aplicación de Gmail (NO es tu contraseña normal)
#
# Cómo generarla (requiere verificación en 2 pasos activa):
# 1. Ve a: https://myaccount.google.com/apppasswords
# 2. En "Nombre de la app" escribe: SkyNova
# 3. Haz clic en Crear
# 4. Copia los 16 caracteres que te da Google
#
EMAIL_PASS=
